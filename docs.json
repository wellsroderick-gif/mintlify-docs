            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/groups",
              "concepts/events",
              "concepts/trust-and-reputation"
            ]
          },
          {
            "group": "Plans & Billing",
            "pages": [
              "billing/plans",
              "billing/event-credits",
              "billing/manage-subscription"
            ]
          }
        ]
      },
      {
        "tab": "Features",
        "groups": [
          {
            "group": "Events",
            "pages": [
              "features/event-types",
              "features/creating-events",
              "features/rsvp-and-waitlist",
              "features/roll-call",
              "features/on-the-table"
