          {
            "group": "Player Tools",
            "pages": [
              "features/discovering-events",
              "features/play-logging",
              "features/bgg-sync",
              "features/game-collection"
            ]
          },
          {
            "group": "Organizer Tools",
            "pages": [
              "features/predictive-attendance",
              "features/recurring-series",
              "features/bringing-list",
              "features/import-meetup"
