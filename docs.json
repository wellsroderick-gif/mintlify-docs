        "groups": [
          {
            "group": "Account & Profile",
            "pages": [
              "help/profile-settings",
              "help/notifications",
              "help/privacy-settings"
            ]
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "help/common-issues",
              "help/contact"
            ]
          }
        ]
