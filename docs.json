  },
  "contextual": {
    "options": ["copy", "view", "assistant"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "introduction",
              "quickstart",
