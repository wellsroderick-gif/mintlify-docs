  "keyFeatures": [
    "Roll Call — automatic pre-event attendance reconfirmation via in-app and SMS",
    "Predictive Attendance — smart estimate of who will actually show up",
    "Trust Score — member reliability rating based on real attendance history",
    "On The Table — coordinate which games members are bringing to events",
    "Three event types: Game Session, Open Game Night, and Custom Event",
    "BGG (BoardGameGeek) collection sync and game search",
    "Flexible group privacy: public, private, and hidden groups with invite links",
    "RSVP and automatic waitlist management",
    "Recurring event series with capacity controls",
    "BG Stats import for play history",
    "Real-time group chat and forum",
    "Reputation system with kudos and achievements",
    "Free tier available; organizer plans starting at $10/month"
  ],
  "publicApiSurface": [
    "GET /events — browse public events",
    "GET /groups — browse public groups",
    "GET /games — browse the game catalog",
    "GET /venues — browse venues",
    "GET /users/:slug — public user profiles",
    "RSVP to events (upsert_my_event_rsvp RPC)",
    "BGG collection sync (bgg-sync Edge Function)",
    "BG Stats import wizard (bgstats-process Edge Function)",
    "Stripe Checkout for plan upgrades (create-checkout-session Edge Function)",
    "Meetup import (import-meetup Edge Function)",
    "Roll Call confirmation flow",
    "Group invite link flow (/invite/:token)",
